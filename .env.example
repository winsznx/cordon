# Cordon — environment template. Copy to .env (gitignored) and fill from Day-0.
# Real values are resolved live from query_chain_config; never hardcode addresses elsewhere.

# --- Monad network (from query_chain_config) ---
MONAD_RPC_URL=
MONAD_CHAIN_ID=
MONAD_EXPLORER=

# --- Deployer (institution / owner) — keep secret, never commit ---
DEPLOYER_PRIVATE_KEY=

# --- Cleanverse sandbox ---
CLEANVERSE_API_BASE=https://uatapi.cleanverse.com/api/skills

# --- Resolved contract / token addresses (from query_chain_config, Monad) ---
AUSDC_ADDRESS=
ACCESS_CORE_ADDRESS=
APASS_ADDRESS=

# --- Agent's three A-Pass-verified wallets (onboarded in Day-0) ---
HOLDING_WALLET=
OPERATING_WALLET=
QUARANTINE_WALLET=
